{
  "ci": {
    "collect": {
      "startServerCommand": "npx serve . -l 4173",
      "startServerReadyPattern": "Accepting connections at",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/thoughts.html",
        "http://localhost:4173/projects.html",
        "http://localhost:4173/404.html",
        "http://localhost:4173/uses.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
